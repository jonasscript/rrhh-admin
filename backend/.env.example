# ── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rrhh_admin
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Email Outlook.com / Microsoft 365 SMTP ────────────────────
# Outlook.com/Hotmail personal: smtp-mail.outlook.com
# Microsoft 365 empresarial:   smtp.office365.com
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@outlook.com
EMAIL_FROM="HABBITA <tu_correo@outlook.com>"
EMAIL_DELIVERY=GRAPH

# Recomendado para Outlook personal: Microsoft Graph + OAuth2.
# Usa `npm run email:outlook-oauth` para generar el refresh token.
EMAIL_AUTH_METHOD=OAUTH2
EMAIL_OAUTH2_CLIENT_ID=application_client_id
EMAIL_OAUTH2_CLIENT_SECRET=client_secret_value
EMAIL_OAUTH2_REFRESH_TOKEN=refresh_token_generado
EMAIL_OAUTH2_TENANT=consumers
EMAIL_OAUTH2_REDIRECT_URI=http://localhost:3002/outlook-oauth2/callback
EMAIL_OAUTH2_SCOPE="offline_access https://graph.microsoft.com/Mail.Send"
EMAIL_OAUTH2_GRAPH_SCOPE=https://graph.microsoft.com/Mail.Send

# Alternativa solo si tu cuenta permite contraseña SMTP/app password:
# EMAIL_AUTH_METHOD=PASSWORD
# EMAIL_PASS=tu_password_o_app_password

# ── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OCR ──────────────────────────────────────────────────
OCR_SCAN_URL=http://localhost:8000/ocr/scan

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
