# OCR Service environment — copy to .env and adjust values

# ─── Application ───────────────────────────────────────────────────────────
APP_NAME=OCR Payment Service
APP_VERSION=1.0.0
DEBUG=false

# ─── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── JWT / OAuth2 ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of "client_id:client_secret" pairs.
# ⚠ Change the secret before deploying to production.
OAUTH_CLIENTS=backend-client:super-secret-change-in-production

# ─── OCR ───────────────────────────────────────────────────────────────────
# Requires OS packages on Debian/Ubuntu:
# apt install tesseract-ocr tesseract-ocr-spa tesseract-ocr-eng
OCR_ENGINE=tesseract
OCR_TESSERACT_LANG=spa+eng
OCR_TESSERACT_CONFIG="--oem 1 --psm 6"
OCR_TESSERACT_CMD=
OCR_TIMEOUT_SECONDS=8
OCR_MAX_DIM=1600

# ─── Upload limits ─────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
