# OCR Service environment — copy to .env and adjust values

# ─── Application ───────────────────────────────────────────────────────────
APP_NAME=OCR Payment Service
APP_VERSION=1.0.0
DEBUG=false

# ─── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── JWT / OAuth2 ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of "client_id:client_secret" pairs.
# ⚠ Change the secret before deploying to production.
OAUTH_CLIENTS=backend-client:super-secret-change-in-production

# ─── OCR ───────────────────────────────────────────────────────────────────
# Comma-separated EasyOCR language codes.
# See: https://www.jaided.ai/easyocr/
OCR_LANGUAGES=es,en
OCR_GPU=false

# ─── Upload limits ─────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
